ARK_API_KEY=your_byteplus_modelark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MODEL_ID=Seed-2.0-mini-260428
STORAGE_DIR=../storage
DATABASE_URL=../storage/db.sqlite3

# Scene detection
# true  = fall back to fixed-size chunks when PySceneDetect fails (default)
# false = raise an error, forcing PySceneDetect to succeed
SCENE_FALLBACK_ENABLED=true
SCENE_FALLBACK_CHUNK_SEC=30
